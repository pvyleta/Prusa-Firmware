driver_pwm_autoscale = True
driver_sgt = 1
coolstep_threshold = 17

[tmc2130 stepper_y]
cs_pin = PG2
interpolate = True
run_current = .300
sense_resistor = 0.220
diag1_pin = !PK7
driver_iholddelay = 8
driver_tpowerdown = 0
driver_tbl = 2
driver_toff = 2
driver_hend = 0
driver_hstrt = 2
